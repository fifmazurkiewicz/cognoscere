# =============================================================
# COGNOSCERE — plik środowiskowy
# Skopiuj jako .env i uzupełnij wartości
# =============================================================

# --- BAZA DANYCH ---
# PostgreSQL — najpierw utwórz pustą bazę (np. CREATE DATABASE cognoscere; w psql).
# Format asyncpg:
DATABASE_URL=postgresql+asyncpg://USER:HASLO@localhost:5432/cognoscere
# Ustaw true przy Google Cloud SQL (public IP) lub gdy serwer wymaga TLS:
# DATABASE_SSL=true

# --- JWT ---
# Wygeneruj własny klucz: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ZMIEN_NA_LOSOWY_KLUCZ_MINIMUM_32_ZNAKI
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- OPENROUTER (LLM — dialog + analiza sesji) ---
# Klucz: https://openrouter.ai/keys
# Domyślnie: Llama 3.1 8B z priorytetem dostawcy Groq (szybko i tanio). Inne modele z Groq na OpenRouter:
#   meta-llama/llama-3.3-70b-instruct  (mocniejszy)
# Lista dostawców: https://openrouter.ai/provider/groq
OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
# Kolejność preferowanych dostawców (puste = automatyczny routing OpenRouter):
# OPENROUTER_PROVIDER_ORDER=Groq
# OPENROUTER_HTTP_REFERER=http://localhost:3000
# OPENROUTER_APP_TITLE=Cognoscere

# --- PIERWSZY ADMINISTRATOR (opcjonalnie) ---
# Jeśli ustawione i nie ma jeszcze użytkownika z tym emailem, zostanie utworzone konto admina przy starcie API.
BOOTSTRAP_ADMIN_EMAIL=
# bcrypt: maks. 72 bajty w UTF-8 (dłuższe hasło zatrzyma start z błędem hashowania)
BOOTSTRAP_ADMIN_PASSWORD=

# --- APLIKACJA ---
DEBUG=true
# true = pełne logi SQLAlchemy (SELECT, BEGIN, ROLLBACK…) w konsoli; zwykle zostaw false
# SQLALCHEMY_ECHO=true
FRONTEND_URL=http://localhost:3000
