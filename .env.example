# =============================================================
# COGNOSCERE — plik środowiskowy
# Skopiuj jako .env i uzupełnij wartości
# =============================================================

# --- BAZA DANYCH ---
# Domyślne dane pasują do docker-compose.yml
DATABASE_URL=postgresql+asyncpg://cognoscere:cognoscere_dev@localhost:5432/cognoscere

# --- REDIS ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
# Wygeneruj własny klucz: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ZMIEN_NA_LOSOWY_KLUCZ_MINIMUM_32_ZNAKI
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- ANTHROPIC (Claude AI) — wymagane do prowadzenia dialogu terapeutycznego ---
# Uzyskaj na: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- GROQ (Whisper — transkrypcja głosu) — wymagane do funkcji głosowej ---
# Uzyskaj na: https://console.groq.com (darmowy tier: 8h audio/dzień)
GROQ_API_KEY=gsk_...

# --- EMAIL (Resend — powiadomienia kryzysowe) --- opcjonalne lokalnie ---
# Uzyskaj na: https://resend.com (darmowy tier: 100 emaili/dzień)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@twoja-domena.pl

# --- APLIKACJA ---
DEBUG=true
FRONTEND_URL=http://localhost:3000
