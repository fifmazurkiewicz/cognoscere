# =============================================================================
# deploy/gcp/.env — Cognoscere na GCP (Cloud SQL + VM + Docker Compose)
# Użycie: cp .env.example .env && chmod 600 .env
#
# W kontenerze backendu NIE ma pliku /app/.env — zmienne pochodzą z env_file Compose.
# Nazwy pól: app/infrastructure/config.py (Pydantic, wielkie litery w środowisku).
# =============================================================================

# --- PostgreSQL (Cloud SQL) — asyncpg; hasło z URL-encode jeśli ma znaki specjalne ---
# Publiczny host/port z konsoli Cloud SQL (Overview → Connect). Authorized networks: IP VM /32.
# Przy błędach połączenia / timeout: ustaw DATABASE_SSL=true (Google wymusza szyfrowany ruch z internetu).
DATABASE_URL=postgresql+asyncpg://cognoscere:TWOJE_HASLO@PUBLICZNY_IP_CLOUD_SQL:5432/cognoscere
# Wymagane przy public IP; backend używa TLS bez weryfikacji CA (typowe dla Cloud SQL — patrz app/infrastructure/database.py).
DATABASE_SSL=true

# --- JWT ---
SECRET_KEY=wygeneruj-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- OpenRouter (LLM) — wymagane do sesji emocjonalnych z modelem ---
OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
# OPENROUTER_PROVIDER_ORDER=Groq

# --- Pierwszy admin (opcjonalnie) — tworzony przy starcie API, jeśli brak konta z tym emailem ---
BOOTSTRAP_ADMIN_EMAIL=admin@twoja-domena.example.com
BOOTSTRAP_ADMIN_PASSWORD=ustaw-silne-haslo-przed-pierwszym-up

# --- Aplikacja ---
DEBUG=false
# SQLALCHEMY_ECHO=true
FRONTEND_URL=https://twoja-domena.example.com
# Dokładnie origin z paska przeglądarki (scheme + host, bez końcowego /) — musi zgadzać się z CORS
# Przykład po IP: FRONTEND_URL=http://203.0.113.10

# --- Frontend (build) — opcjonalnie; puste = przeglądarka woła /api na tym samym hoście co strona ---
# NEXT_PUBLIC_API_URL=

# =============================================================================
# Nginx edge łączy przeglądarkę: https://domena/ → Next, https://domena/api/ → FastAPI.
# Nie otwieraj publicznie portu 8000 — tylko 80/443 na Caddy i 8080 tylko na 127.0.0.1.
# =============================================================================
