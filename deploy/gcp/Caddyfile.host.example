# Caddy na hoście VM — proxy do kontenera edge (nginx) na 127.0.0.1:8080.
# Wcięcia w blokach Caddy: tabulatory. Szczegóły: docs/GCP_KROK_PO_KROKU.md
#
# Przed HTTPS: rekord DNS typu A dla hosta poniżej musi wskazywać na zewnętrzne IP VM;
# na GCP firewall: dozwolony ruch przychodzący TCP 443 (i 80 — weryfikacja / przekierowanie).
#
# --- Tylko HTTP (np. test po http://ZEWNETRZNE_IP) — zakomentuj blok DuckDNS i odkomentuj: ---
# :80 {
# 	reverse_proxy 127.0.0.1:8080
# }

cognoscere.duckdns.org {
	reverse_proxy 127.0.0.1:8080
}
